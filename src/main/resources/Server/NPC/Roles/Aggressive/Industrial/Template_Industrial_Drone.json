{
  "Type": "Abstract",
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Hostile",
  "AttitudeGroup": {
    "Compute": "AttitudeGroup"
  },
  "BusyStates": [
    "Alerted",
    "Chase",
    "Search",
    "ReturnHome"
  ],
  "Parameters": {
    "Appearance": {
      "Value": "Industrial_drone",
      "Description": "Model to be used"
    },
    "ViewRange": {
      "Value": 30,
      "Description": "View range"
    },
    "ViewSector": {
      "Value": 360,
      "Description": "Full 360 view sector (flying unit)"
    },
    "HearingRange": {
      "Value": 24,
      "Description": "Hearing range"
    },
    "AbsoluteDetectionRange": {
      "Value": 10,
      "Description": "Guaranteed detection distance"
    },
    "AlertedRange": {
      "Value": 54,
      "Description": "Detection range while in combat/search"
    },
    "LeashDistance": {
      "Value": 60,
      "Description": "Distance before returning to spawn"
    },
    "LeashMinPlayerDistance": {
      "Value": 7,
      "Description": "Minimum player distance before leash can force return"
    },
    "LeashTimer": {
      "Value": [8, 8],
      "Description": "Time spent out of leash range before returning"
    },
    "HardLeashDistance": {
      "Value": 220,
      "Description": "Absolute max distance from spawn"
    },
    "DropList": {
      "Value": "Drop_UnstableRifts_Industrial_Combat",
      "Description": "Drop items"
    },
    "MaxSpeed": {
      "Value": 8.0,
      "Description": "Maximum flying speed"
    },
    "RelativeChaseSpeed": {
      "Value": 0.7,
      "Description": "Relative chase speed"
    },
    "AttackSequence": {
      "Value": "Component_Instruction_Attack_Sequence_Industrial_Drone",
      "Description": "Ranged barrel throw attack sequence"
    },
    "AttackDistance": {
      "Value": 15,
      "Description": "Distance at which barrel throw is executed"
    },
    "DashAttack": {
      "Value": "Root_Industrial_Drone_Dash",
      "Description": "The dash attack when target is at close-medium range"
    },
    "DashDistance": {
      "Value": 10.0,
      "Description": "Maximum distance for initiating a dash"
    },
    "DashMinDistance": {
      "Value": 4.0,
      "Description": "Minimum distance before the NPC will dash"
    },
    "TargetGroups": {
      "Value": ["Industrial_Drone"],
      "Description": "Beacon target groups"
    },
    "DisableDamageGroups": {
      "Value": ["Self", "Industrial"],
      "Description": "Groups not to take damage from"
    },
    "AttitudeGroup": {
      "Value": "Industrial",
      "Description": "Attitude group"
    },
    "CombatRelativeTurnSpeed": {
      "Value": 2.0,
      "Description": "Turn speed modifier in combat"
    },
    "MaxHealth": {
      "Value": 80,
      "Description": "Max health for the NPC"
    },
    "IsMemory": {
      "Value": true,
      "Description": "Defines if the NPC is a memory"
    },
    "MemoriesCategory": {
      "Value": "Industrial",
      "Description": "Defines the memory category"
    },
    "MemoriesNameOverride": {
      "Value": "Industrial_Drone",
      "Description": "Memory name override"
    },
    "NameTranslationKey": {
      "Value": "bettermobs.npcRoles.Industrial_Drone.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "IsMemory": {
    "Compute": "IsMemory"
  },
  "MemoriesCategory": {
    "Compute": "MemoriesCategory"
  },
  "MemoriesNameOverride": {
    "Compute": "MemoriesNameOverride"
  },
  "Appearance": {
    "Compute": "Appearance"
  },
  "DropList": {
    "Compute": "DropList"
  },
  "DisableDamageGroups": {
    "Compute": "DisableDamageGroups"
  },
  "KnockbackScale": 0.3,
  "MotionControllerList": [
    {
      "Type": "Fly",
      "MaxHorizontalSpeed": {
        "Compute": "MaxSpeed"
      },
      "MaxSinkSpeed": 3,
      "MaxClimbSpeed": 10,
      "MinAirSpeed": 2,
      "Acceleration": 8,
      "MinHeightOverGround": 4,
      "MaxHeightOverGround": 6,
      "MaxRollAngle": 15,
      "MaxTurnSpeed": 270,
      "DesiredAltitudeWeight": 1,
      "AutoLevel": true
    }
  ],
  "MaxHealth": {
    "Compute": "MaxHealth"
  },
  "Instructions": [
    {
      "$Comment": "Global beacon listener: allies signal that an enemy was found.",
      "Continue": true,
      "Sensor": {
        "Type": "Beacon",
        "Message": "IndustrialDrone_EnemyFound",
        "TargetSlot": "LockedTarget",
        "Range": {
          "Compute": "HearingRange * 2"
        }
      },
      "Actions": [
        {
          "Type": "State",
          "State": "Chase"
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Idle"
      },
      "Instructions": [
        {
          "Reference": "Component_Instruction_Damage_Check",
          "Modify": {
            "_ExportStates": [
              "Chase",
              "Search"
            ],
            "AlertedRange": {
              "Compute": "AlertedRange"
            }
          }
        },
        {
          "Sensor": {
            "Reference": "Component_Sensor_Standard_Detection",
            "Modify": {
              "ViewRange": {
                "Compute": "ViewRange"
              },
              "ViewSector": {
                "Compute": "ViewSector"
              },
              "HearingRange": {
                "Compute": "HearingRange"
              },
              "AbsoluteDetectionRange": {
                "Compute": "AbsoluteDetectionRange"
              },
              "Attitudes": [
                "Hostile"
              ]
            }
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": {
                "Compute": "HearingRange * 2"
              },
              "Message": "IndustrialDrone_EnemyFound",
              "TargetGroups": {
                "Compute": "TargetGroups"
              },
              "SendTargetSlot": "LockedTarget"
            },
            {
              "Type": "State",
              "State": "Alerted"
            }
          ]
        },
        {
          "$Comment": "Idle wander: drift slowly in the air.",
          "Sensor": {
            "Type": "Any"
          },
          "BodyMotion": {
            "Type": "Wander",
            "RelativeSpeed": 0.3,
            "MinWalkTime": 3,
            "MaxWalkTime": 6,
            "TestsPerTick": 1,
            "MinHeadingChange": 0,
            "MaxHeadingChange": 120,
            "RelaxHeadingChange": true
          }
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Alerted"
      },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "Any",
            "Once": true
          },
          "Actions": [
            {
              "Type": "PlayAnimation",
              "Slot": "Status",
              "Animation": "Alerted"
            }
          ]
        },
        {
          "Continue": true,
          "Sensor": {
            "Type": "Target"
          },
          "HeadMotion": {
            "Type": "Aim",
            "Spread": 0,
            "HitProbability": 1
          }
        },
        {
          "Sensor": {
            "Type": "Any"
          },
          "Actions": [
            {
              "Type": "Timeout",
              "Delay": [1.5, 1.5],
              "Action": {
                "Type": "State",
                "State": "Chase"
              }
            }
          ]
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Chase"
      },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "Any",
            "Once": true
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": {
                "Compute": "HearingRange * 2"
              },
              "Message": "IndustrialDrone_EnemyFound",
              "TargetGroups": {
                "Compute": "TargetGroups"
              },
              "SendTargetSlot": "LockedTarget"
            }
          ]
        },
        {
          "$Comment": "Switch target to whoever is attacking us and mark them as hostile.",
          "Continue": true,
          "Sensor": {
            "Type": "Damage",
            "Combat": true,
            "TargetSlot": "LockedTarget"
          },
          "Actions": [
            {
              "Type": "OverrideAttitude",
              "Attitude": "Hostile",
              "Duration": 60
            },
            {
              "Type": "AddToHostileTargetMemory"
            }
          ]
        },
        {
          "$Comment": "Only continue combat if a valid hostile target is detected or remembered.",
          "Sensor": {
            "Type": "Or",
            "Sensors": [
              {
                "Reference": "Component_Sensor_Standard_Detection",
                "Modify": {
                  "ViewRange": {
                    "Compute": "AlertedRange"
                  },
                  "ViewSector": {
                    "Compute": "ViewSector"
                  },
                  "HearingRange": {
                    "Compute": "HearingRange"
                  },
                  "AbsoluteDetectionRange": {
                    "Compute": "AbsoluteDetectionRange"
                  },
                  "Attitudes": [
                    "Hostile"
                  ]
                }
              },
              {
                "Type": "HasHostileTargetMemory"
              }
            ]
          },
          "Instructions": [
            {
              "Reference": "Component_Instruction_Clear_Status_Animation"
            },
            {
              "$Comment": "Maintain altitude at 4-6 blocks over ground during combat (2-4 blocks above player).",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "OverrideAltitude",
                  "DesiredAltitudeRange": [4, 6]
                }
              ]
            },
            {
              "$Comment": "RANGED: Throw radioactive barrels at the target from range.",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AttackDistance"
                },
                "Filters": [
                  {
                    "Type": "LineOfSight"
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "Attack",
                  "Attack": "Root_Industrial_Drone_Barrel_Throw",
                  "BallisticMode": "Short",
                  "AimingTimeRange": [1.0, 1.5],
                  "AttackPauseRange": [2.5, 4.0]
                }
              ],
              "HeadMotion": {
                "Type": "Aim",
                "Spread": 0.3,
                "HitProbability": 0.65,
                "Deflection": true,
                "RelativeTurnSpeed": {
                  "Compute": "CombatRelativeTurnSpeed"
                }
              }
            },
            {
              "$Comment": "DASH: when target is at close-medium range (4-10 blocks), dash toward them.",
              "Continue": true,
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Target",
                    "Range": {
                      "Compute": "DashDistance"
                    },
                    "Filters": [
                      {
                        "Type": "LineOfSight"
                      }
                    ]
                  },
                  {
                    "Type": "Not",
                    "Sensor": {
                      "Type": "Target",
                      "Range": {
                        "Compute": "DashMinDistance"
                      }
                    }
                  }
                ]
              },
              "ActionsBlocking": false,
              "Actions": [
                {
                  "Type": "Attack",
                  "Attack": {
                    "Compute": "DashAttack"
                  },
                  "AttackPauseRange": [0.5, 1.0]
                }
              ]
            },
            {
              "Reference": "Component_Instruction_Soft_Leash",
              "Modify": {
                "_ExportStates": [
                  "ReturnHome"
                ],
                "LeashDistance": {
                  "Compute": "LeashDistance"
                },
                "LeashMinPlayerDistance": {
                  "Compute": "LeashMinPlayerDistance"
                },
                "LeashTimer": {
                  "Compute": "LeashTimer"
                },
                "HardLeashDistance": {
                  "Compute": "HardLeashDistance"
                }
              }
            },
            {
              "$Comment": "Fly toward target to stay within attack range, following the player.",
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AlertedRange"
                }
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": 12,
                "StopDistance": 6,
                "RelativeSpeed": {
                  "Compute": "RelativeChaseSpeed"
                }
              }
            },
            {
              "$Comment": "Target out of range during chase, transition to search.",
              "Actions": [
                {
                  "Type": "State",
                  "State": "Search"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "No valid hostile target found - go to search.",
          "Actions": [
            {
              "Type": "State",
              "State": "Search"
            }
          ]
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Search"
      },
      "Instructions": [
        {
          "$Comment": "Re-enter chase if attacked during search.",
          "Sensor": {
            "Type": "Damage",
            "Combat": true,
            "TargetSlot": "LockedTarget"
          },
          "Actions": [
            {
              "Type": "AddToHostileTargetMemory"
            },
            {
              "Type": "State",
              "State": "Chase"
            }
          ]
        },
        {
          "Continue": true,
          "Sensor": {
            "Type": "Any",
            "Once": true
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": {
                "Compute": "HearingRange * 2"
              },
              "Message": "IndustrialDrone_EnemyFound",
              "TargetGroups": {
                "Compute": "TargetGroups"
              },
              "SendTargetSlot": "LockedTarget"
            }
          ]
        },
        {
          "$Comment": "Re-detect hostile target during search.",
          "Sensor": {
            "Reference": "Component_Sensor_Standard_Detection",
            "Modify": {
              "ViewRange": {
                "Compute": "ViewRange"
              },
              "ViewSector": {
                "Compute": "ViewSector"
              },
              "HearingRange": {
                "Compute": "HearingRange"
              },
              "AbsoluteDetectionRange": {
                "Compute": "AbsoluteDetectionRange"
              },
              "Attitudes": [
                "Hostile"
              ]
            }
          },
          "Actions": [
            {
              "Type": "State",
              "State": "Chase"
            }
          ]
        },
        {
          "$Comment": "Wander around the search area, return to idle after timeout.",
          "Sensor": {
            "Type": "Any"
          },
          "Actions": [
            {
              "Type": "Timeout",
              "Delay": [8, 12],
              "Action": {
                "Type": "State",
                "State": "Idle"
              }
            }
          ],
          "BodyMotion": {
            "Type": "Wander",
            "RelativeSpeed": 0.4,
            "MinWalkTime": 2,
            "MaxWalkTime": 4,
            "TestsPerTick": 1,
            "MinHeadingChange": 0,
            "MaxHeadingChange": 180,
            "RelaxHeadingChange": true
          }
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "ReturnHome"
      },
      "Instructions": [
        {
          "Sensor": {
            "Type": "Leash",
            "Range": {
              "Compute": "LeashDistance * 0.3"
            }
          },
          "BodyMotion": {
            "Type": "Seek",
            "SlowDownDistance": 1,
            "StopDistance": 0.5,
            "RelativeSpeed": 1
          }
        },
        {
          "Actions": [
            {
              "Type": "State",
              "State": "Idle"
            }
          ]
        }
      ]
    }
  ],
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  }
}
