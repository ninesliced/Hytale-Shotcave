// ─────────────────────────────────────────────
//  Shotcave — Weapon HUD
//  Compact ammo counter with progress bar
// ─────────────────────────────────────────────

@DimText = #6b7d94;
@BrightText = #e8ecf0;
@AmmoFull = #7aa8d4;
@BarTrack = #1a1f2a;
@PanelBg = #0c0f14(0.82);

Group #ShotcaveHudRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;

  // ── Main container — bottom-right ──
  Group #ShotcaveAmmoRoot {
    Anchor: (Width: 200, Height: 80, Bottom: 24, Left: 24);
    Background: @PanelBg;
    LayoutMode: Top;
    Padding: (Horizontal: 14, Vertical: 10);
    Visible: false;

    // ── Row 1: Weapon name ──
    Label #ShotcaveWeaponName {
      Text: "WEAPON";
      Anchor: (Height: 18);
      Style: LabelStyle(
        FontSize: 11,
        TextColor: @DimText,
        RenderUppercase: true,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    // ── Row 2: Ammo counter (big current / small max) ──
    Group {
      Anchor: (Height: 32, Top: 2);
      LayoutMode: Left;

      Label #ShotcaveAmmoValue {
        Text: "0";
        Anchor: (Height: 32);
        Style: LabelStyle(
          FontName: "Mono",
          FontSize: 30,
          TextColor: @BrightText,
          VerticalAlignment: End,
          HorizontalAlignment: Start
        );
      }

      Label {
        Text: "/";
        Anchor: (Height: 32, Left: 4, Right: 2);
        Style: LabelStyle(
          FontName: "Mono",
          FontSize: 16,
          TextColor: @DimText,
          VerticalAlignment: End,
          HorizontalAlignment: Center
        );
      }

      Label #ShotcaveMaxAmmoValue {
        Text: "0";
        Anchor: (Height: 32);
        Style: LabelStyle(
          FontName: "Mono",
          FontSize: 16,
          TextColor: @DimText,
          VerticalAlignment: End,
          HorizontalAlignment: Start
        );
      }
    }

    // ── Row 3: Ammo bar ──
    Group #ShotcaveAmmoBarTrack {
      Anchor: (Height: 4, Top: 6, Left: 0, Right: 0);
      Background: @BarTrack;

      Group #ShotcaveAmmoBarFill {
        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        Background: @AmmoFull;
      }
    }
  }
}
