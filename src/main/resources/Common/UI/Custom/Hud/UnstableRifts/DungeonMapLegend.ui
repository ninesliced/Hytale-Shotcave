@PanelBg = #0b1118(0.86);
@RowBg = #111923(0.74);
@Divider = #203041(0.92);
@Heading = #d9c18a;
@Body = #e8ecf0;
@Muted = #93a8bb;
@Count = #c8d4df;

Group #DungeonMapLegend {
  Anchor: (Width: 300, Height: 284, Top: 24, Right: 0);
  Background: @PanelBg;
  Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
  LayoutMode: Top;
  HitTestVisible: false;

  Label #LegendTitle {
    Anchor: (Height: 22);
    Text: "Rift Map Legend";
    Style: LabelStyle(
      FontSize: 14,
      TextColor: @Heading,
      RenderBold: true,
      RenderUppercase: true,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #LegendSubtitle {
    Anchor: (Height: 18, Top: 2);
    Text: "Unknown Floor";
    Style: LabelStyle(
      FontSize: 11,
      TextColor: @Muted,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Group {
    Anchor: (Height: 2, Top: 8);
    Background: @Divider;
  }

  Group #SpawnRow {
    Anchor: (Height: 24, Top: 10);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #SpawnSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #4ade80;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Spawn";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #SpawnCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  Group #CorridorRow {
    Anchor: (Height: 24, Top: 4);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #CorridorSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #6b7d94;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Corridor";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #CorridorCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  Group #ChallengeRow {
    Anchor: (Height: 24, Top: 4);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #ChallengeSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #60a5fa;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Challenge";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #ChallengeCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  Group #TreasureRow {
    Anchor: (Height: 24, Top: 4);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #TreasureSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #fbbf24;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Treasure";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #TreasureCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  Group #ShopRow {
    Anchor: (Height: 24, Top: 4);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #ShopSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #a78bfa;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Shop";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #ShopCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }

  Group #BossRow {
    Anchor: (Height: 24, Top: 4);
    Background: @RowBg;
    Padding: (Left: 8, Right: 8);
    LayoutMode: Left;

    Group #BossSwatch {
      Anchor: (Width: 14, Height: 14, Top: 5);
      Background: #ef4444;
    }

    Group { Anchor: (Width: 8); }

    Label {
      FlexWeight: 1;
      Anchor: (Height: 24);
      Text: "Boss";
      Style: LabelStyle(FontSize: 11, TextColor: @Body, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
    }

    Label #BossCount {
      Anchor: (Width: 66, Height: 24);
      Text: "0 rooms";
      Style: LabelStyle(FontSize: 10, TextColor: @Count, HorizontalAlignment: End, VerticalAlignment: Center);
    }
  }
}