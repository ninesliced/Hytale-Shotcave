// ─────────────────────────────────────────────
//  UnstableRifts — Shop Item Pool Entry (template row)
//  Used for both weapon and armor pool lists.
//  [Dropdown] | -[Weight]+ | [X]
// ─────────────────────────────────────────────

$C = "../../Common.ui";

@EntryBg = #222838;
@LblColor = #e8ecf0;
@RemoveBg = #3a2020;
@RemoveHover = #5a3030;
@BtnBg = #2a3040;
@BtnHover = #3a4560;
@SmallLabelStyle = LabelStyle(FontSize: 11, TextColor: @LblColor, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@SmallBtnStyle = TextButtonStyle(
  Default: (Background: @BtnBg, LabelStyle: @SmallLabelStyle),
  Hovered: (Background: @BtnHover, LabelStyle: @SmallLabelStyle),
  Pressed: (Background: @BtnBg, LabelStyle: @SmallLabelStyle)
);
@RemoveLabelStyle = LabelStyle(FontSize: 12, TextColor: #ff6666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@RemoveBtnStyle = TextButtonStyle(
  Default: (Background: @RemoveBg, LabelStyle: @RemoveLabelStyle),
  Hovered: (Background: @RemoveHover, LabelStyle: @RemoveLabelStyle),
  Pressed: (Background: @RemoveBg, LabelStyle: @RemoveLabelStyle)
);

Group #PoolEntry {
  LayoutMode: Left;
  Anchor: (Height: 34, Bottom: 4);
  Background: @EntryBg;
  Padding: (Left: 4, Right: 4, Top: 3, Bottom: 3);

  // Dropdown selector for weapon/armor
  $C.@DropdownBox #EntryDropdown {
    @Anchor = (Width: 200);
    Value: "";
  }

  // Spacer
  Label { Anchor: (Width: 8, Height: 1); }

  // Weight controls
  TextButton #WeightMinusBtn {
    Text: "-";
    Anchor: (Width: 22, Height: 24);
    Style: @SmallBtnStyle;
  }

  Label #WeightLabel {
    Text: "1";
    Anchor: (Width: 32, Height: 24);
    Style: LabelStyle(FontSize: 12, TextColor: @LblColor, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
  }

  TextButton #WeightPlusBtn {
    Text: "+";
    Anchor: (Width: 22, Height: 24);
    Style: @SmallBtnStyle;
  }

  // Spacer
  Label { Anchor: (Width: 6, Height: 1); }

  // Remove button
  TextButton #RemoveBtn {
    Text: "X";
    Anchor: (Width: 28, Height: 24);
    Style: @RemoveBtnStyle;
  }
}
